<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ai_concierge.Chat" owl="1">
        <div class="ai-concierge-chat-panel d-flex flex-column h-100 bg-white border-start shadow-sm">
            <!-- Header -->
            <div class="p-3 bg-primary text-white d-flex justify-content-between align-items-center rounded-0">
                <h5 class="mb-0 ai_concierge_header_title"><i class="fa fa-magic me-2"/>AI Concierge</h5>
                <button class="btn btn-sm btn-light" t-on-click="props.closeChat"><i class="fa fa-times"/></button>
            </div>

            <!-- Message Area -->
            <div class="flex-grow-1 p-3 overflow-auto d-flex flex-column gap-3 scroll-smooth" 
                 t-ref="messageArea"
                 style="background-color: #f0f2f5;">
                <t t-foreach="state.messages" t-as="msg" t-key="msg_index">
                    <div t-attf-class="message-bubble-container d-flex flex-column {{ msg.role === 'user' ? 'align-items-end' : 'align-items-start' }}">
                        <div t-attf-class="message-bubble p-3 shadow-none {{ msg.role === 'user' ? 'user-bubble' : 'ai-bubble' }}"
                             style="max-width: 90%; position: relative;">
                            
                            <!-- Content -->
                            <div class="message-content text-break">
                                <t t-out="msg.content"/>
                                <t t-if="msg.a2ui_surface">
                                    <A2UISurface surface="msg.a2ui_surface"/>
                                </t>
                            </div>
                            
                            <!-- Timestamp/Meta if needed -->
                            <div t-attf-class="small mt-1 opacity-50 {{ msg.role === 'user' ? 'text-end' : '' }}" style="font-size: 0.7rem;">
                                <t t-if="msg.role === 'ai'"><i class="fa fa-robot me-1"/>AI Concierge</t>
                                <t t-else=""><i class="fa fa-user me-1"/>Tú</t>
                            </div>
                        </div>
                    </div>
                </t>
                <div t-if="state.isLoading" class="ai-typing-indicator p-2 rounded-pill bg-white border align-self-start shadow-sm small">
                    <span class="dot-typing mx-2"><i class="fa fa-circle-o-notch fa-spin me-1"/> Escuchando...</span>
                </div>
            </div>

            <!-- Attachment Previews -->
            <div t-if="state.attachments.length > 0" class="p-2 border-top bg-light d-flex gap-2 overflow-auto">
                <t t-foreach="state.attachments" t-as="att" t-key="att.id">
                    <div class="position-relative bg-white border rounded p-1" style="width: 60px; height: 60px;">
                        <img t-if="att.type.startsWith('image/')" t-att-src="att.preview" class="w-100 h-100 object-fit-cover rounded"/>
                        <div t-else="" class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                            <i class="fa fa-file-o"/>
                        </div>
                        <button class="btn btn-sm btn-danger position-absolute top-0 end-0 p-0 rounded-circle" 
                                style="width: 16px; height: 16px; line-height: 12px; font-size: 10px;"
                                t-on-click="() => this.removeAttachment(att.id)">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                </t>
            </div>

            <!-- Input Area -->
            <div class="p-3 border-top bg-white">
                <div class="input-group">
                    <input type="file" t-ref="fileInput" class="d-none" t-on-change="onFileChange" multiple="true" accept="image/*,application/pdf"/>
                    <button class="btn btn-outline-secondary" t-on-click="triggerFileInput">
                        <i class="fa fa-paperclip"/>
                    </button>
                    <input type="text" class="form-control border-start-0" placeholder="Pídele algo a tu ERP..." 
                           t-model="state.inputText" t-on-keydown="onKeydown"/>
                    <button class="btn btn-primary" t-on-click="sendMessage" t-att-disabled="state.isLoading">
                        <i class="fa fa-paper-plane"/>
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
